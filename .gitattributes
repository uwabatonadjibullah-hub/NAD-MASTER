# Auto-detect text files and perform LF normalization
* text=auto

# Gradle wrapper scripts must use LF on all platforms (for Linux CI runners)
gradlew        text eol=lf
gradlew.bat    text eol=crlf

# Binary files
*.jar          binary
*.apk          binary
*.aab          binary
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.webp         binary
*.ico          binary
*.pdf          binary
*.ttf          binary
*.woff         binary
*.woff2        binary
