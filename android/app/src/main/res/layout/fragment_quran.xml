<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qur'an Tracker"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:fontFamily="serif"
            android:layout_marginBottom="24dp" />

        <!-- Current Juzz -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_container"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CURRENT SURAH"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvCurrentSurah"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Progress -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_container"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/outline"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEMORIZATION PROGRESS"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvJuzzProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 30 Juzz"
                    android:textColor="@color/on_surface"
                    android:textSize="24sp"
                    android:fontFamily="serif"
                    android:layout_marginBottom="12dp" />

                <ProgressBar
                    android:id="@+id/quranProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progress="0"
                    android:max="30"
                    android:progressTint="@color/primary"
                    android:progressBackgroundTint="@color/outline" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Update button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpdateQuranProgress"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Update Progress"
            android:textColor="@color/on_primary"
            app:backgroundTint="@color/primary"
            app:cornerRadius="4dp" />

    </LinearLayout>
</ScrollView>
