rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---

    function isValidGoal(data) {
      return data.userId == request.auth.uid
        && data.title is string
        && data.title.size() >= 1
        && data.title.size() <= 300
        && data.status in ['active', 'completed', 'failed'];
    }

    function isValidScheduleBlock(data) {
      return data.userId == request.auth.uid
        && data.title is string
        && data.title.size() <= 200;
    }

    function isValidChatMessage(data) {
      return data.userId == request.auth.uid
        && data.role in ['user', 'assistant']
        && data.content is string
        && data.content.size() <= 10000;
    }

    function isValidDhikrSession(data) {
      return data.userId == request.auth.uid
        && data.category is string
        && data.category.size() <= 100;
    }

    // --- User document ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId)
        && incoming().uid == request.auth.uid
        && incoming().email is string;
      allow update: if isOwner(userId)
        && incoming().diff(existing()).affectedKeys()
            .hasOnly(['displayName', 'photoURL', 'preferences', 'statistics', 'updatedAt']);

      // Schedule blocks
      match /schedule/{blockId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidScheduleBlock(incoming());
        allow update: if isOwner(userId) && isValidScheduleBlock(incoming())
          && incoming().diff(existing()).affectedKeys()
              .hasOnly(['title', 'type', 'startTime', 'endTime', 'description', 'isCompleted']);
        allow delete: if isOwner(userId);
      }

      // Goals (used by Dashboard real-time stats)
      match /goals/{goalId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidGoal(incoming());
        allow update: if isOwner(userId) && isValidGoal(incoming())
          && incoming().diff(existing()).affectedKeys()
              .hasOnly(['status', 'title', 'updatedAt']);
        allow delete: if isOwner(userId);
      }

      // Chat messages
      match /chats/{messageId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChatMessage(incoming());
      }

      // Dhikr sessions (tracks completed sessions per user)
      match /dhikrSessions/{sessionId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidDhikrSession(incoming());
        allow delete: if isOwner(userId);
      }

      // Quran progress
      match /quranProgress/main {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && incoming().userId == userId;
      }

      match /quranHistory/{date} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && incoming().userId == userId;
      }

      match /quranGoals/{goalId} {
        allow list, get: if isOwner(userId);
        allow create, update, delete: if isOwner(userId) && incoming().userId == userId;
      }

      match /journal/{entryId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && incoming().userId == userId;
      }
    }
  }
}
